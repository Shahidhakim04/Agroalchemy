# Copy this file to .env and fill in your values.
# Required for the in-app chatbot (Google Gemini):
GEMINI_API_KEY=your_gemini_api_key_here

# Optional – backend API (if you run your own server):
# API_BASE_URL=http://localhost:5000

# Optional – email / Twilio (if you use those features):
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
